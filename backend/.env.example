# Server
PORT=2901
NODE_ENV=development

# LLM
LLM_PROVIDER=local
LLM_API_BASE=http://localhost:8317/v1
LLM_API_KEY=
# LLM_API_KEY_FILE=/run/secrets/llm_api_key
LLM_MODEL=local-model
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# CORS
CORS_ORIGIN=http://localhost:2101

# Auth
AUTH_ENABLED=false
AUTH_API_KEYS=dev-key
# AUTH_API_KEYS_FILE=/run/secrets/auth_api_keys
AUTH_ADMIN_API_KEY=

# Public sessions (optional — cookie-based ephemeral sessions for unauthenticated users)
# AUTH_PUBLIC_SESSIONS_ENABLED=false
# AUTH_PUBLIC_SESSION_SECRET=
# AUTH_PUBLIC_SESSION_COOKIE_NAME=argus_public_session
# AUTH_PUBLIC_SESSION_TTL_DAYS=30

# Trusted proxy (set to number of reverse-proxy hops for correct client IP resolution)
# TRUST_PROXY_HOPS=0

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_BACKEND=sqlite
RATE_LIMIT_STORE_FILE=data/rate-limit.db
# RATE_LIMIT_REDIS_URL=redis://localhost:6379/0

# Memory lifecycle (optional — default 6 hours)
# MEMORY_LIFECYCLE_INTERVAL_MS=21600000

# LLM completion timeout (default 45s, increase for slow models)
# LLM_COMPLETION_TIMEOUT_MS=120000

# Embedding (optional — enables semantic memory search)
EMBEDDING_ENABLED=false
# Provider: 'local' runs in-process via Transformers.js (no external server needed)
#           'api' calls an OpenAI-compatible /embeddings endpoint
# EMBEDDING_PROVIDER=local
# EMBEDDING_LOCAL_MODEL=Xenova/multilingual-e5-small
# For API provider only:
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_BASE=http://localhost:8317/v1
# EMBEDDING_API_KEY=
# EMBEDDING_DIMENSIONS=0

# Qdrant (optional — enables vector-based semantic recall)
# MEMORY_QDRANT_URL=http://localhost:6333
# MEMORY_QDRANT_API_KEY=
# MEMORY_QDRANT_COLLECTION=argus_memory
# MEMORY_QDRANT_VECTOR_SIZE=384

# Tool safety policy (controls which tool safety levels are allowed)
# permissive — all tools allowed (default, good for local-first usage)
# standard   — safe + moderate allowed, dangerous blocked
# strict     — only safe tools allowed
# TOOLS_SAFETY_POLICY=permissive
# TOOLS_BLOCKED_NAMES=process,applescript
# TOOLS_ALLOWED_NAMES=system_run

# Audio transcription (local Whisper via Transformers.js — auto-downloads model)
# TOOLS_AUDIO_TRANSCRIBE_ENABLED=true
# TOOLS_AUDIO_TRANSCRIBE_MODEL=Xenova/whisper-base
# Available models: Xenova/whisper-tiny (~75MB), Xenova/whisper-base (~150MB), Xenova/whisper-small (~460MB)

# Telegram Bot (optional — enables Telegram as a second chat channel)
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789,987654321
# TELEGRAM_WEBHOOK_URL=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_PROGRESSIVE_EDIT=false
# TELEGRAM_EDIT_INTERVAL_MS=1500

# Telegram Client / Userbot (optional — connect as a user account via MTProto)
# Get API credentials at https://my.telegram.org
# TELEGRAM_CLIENT_ENABLED=false
# TELEGRAM_CLIENT_API_ID=12345678
# TELEGRAM_CLIENT_API_HASH=your_api_hash_here
# Auth flow: POST /api/telegram-client/auth/send-code → /auth/sign-in → /auth/2fa (if needed)
# Or configure via Settings API: telegram_client.api_id, telegram_client.api_hash

# Settings encryption (recommended for production — encrypts sensitive values stored via Settings API)
# SETTINGS_ENCRYPTION_SECRET=
# SETTINGS_ENCRYPTION_SECRET_FILE=/run/secrets/settings_encryption_secret

# SQL Query tool (optional — query SQLite files and PostgreSQL databases)
# TOOLS_SQL_QUERY_ENABLED=true
# TOOLS_SQL_QUERY_ALLOW_WRITE=false
# PostgreSQL connections are configured via Settings API: key "tools.sql_query.pg.<name>", value = connection string

# AppleScript tool (optional — macOS automation via osascript, only registered on macOS)
# TOOLS_APPLESCRIPT_ENABLED=true
# TOOLS_APPLESCRIPT_TIMEOUT_MS=15000

# Document generation tool (optional — generate PDF/HTML from Markdown)
# TOOLS_DOCUMENT_GEN_ENABLED=true
# TOOLS_DOCUMENT_GEN_OUTPUT_DIR=data/documents

# Email tool (credentials stored in Settings API, not .env — each user has their own mailbox)
# TOOLS_EMAIL_ENABLED=true
# Configure via Settings API: tools.email.provider, tools.email.email, tools.email.password
# Supported providers: gmail, outlook, yandex, mailru, icloud, custom

# ─── Webhooks ─────────────────────────────────────────────────────────────────
# Enable/disable inbound webhook endpoints (POST /api/hooks/:name)
HOOKS_ENABLED=true

# Soul / identity customization (optional — path to custom soul YAML config)
# SOUL_CONFIG_PATH=data/soul.yml

# Storage
STORAGE_DRIVER=sqlite
STORAGE_DATA_FILE=data/chat-store.json
STORAGE_DB_FILE=data/chat.db
STORAGE_MEMORY_DB_FILE=data/memory.db
# STORAGE_POSTGRES_URL=postgres://argus:argus@localhost:5432/argus
