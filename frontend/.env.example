VITE_API_BASE=/api
VITE_DEV_PROXY_TARGET=http://localhost:2901

# Server-side only (never exposed to the browser).
# The Vite dev proxy and nginx inject this as X-API-Key header.
API_KEY=
# Admin API key (full access including settings/memory-admin endpoints).
# Generated automatically by `argus-one onboard` when auth is enabled.
ADMIN_API_KEY=
